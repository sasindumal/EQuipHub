# For local development with physical devices (Android/iOS)
# Use your machine's local IP address, e.g.,
# EXPO_PUBLIC_API_URL=http://192.168.1.100:8080/api/v1
#
# For simulators/emulators, localhost routing is handled automatically 
# if this variable is left empty/commented, but you can override here:
EXPO_PUBLIC_API_URL=http://localhost:8080/api/v1
